generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum BotStatus {
  PENDING_REVIEW
  ACTIVE
  BLOCKED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  REFUNDED
  CANCELLED
  EXPIRED
}

enum EventType {
  PAGE_VIEW
  VIEW_CONTENT
  LEAD
  INITIATE_CHECKOUT
  ADD_PAYMENT_INFO
  PURCHASE
  START
  MESSAGE_SENT
  BUTTON_CLICKED
  PAYMENT_PIX
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  password     String
  avatar       String?
  role         UserRole    @default(USER)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  workspaces   Workspace[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bots        TelegramBot[]
  leads       Lead[]
  products    Product[]
  flows       Flow[]
  automations Automation[]
  segments    Segment[]
  redirectors Redirector[]
  facebookIntegration FacebookIntegration?
  facebookPixels      FacebookPixel[]
  kwaiIntegration     KwaiIntegration?
  kwaiAccounts        KwaiAccount[]
  kwaiEventLogs       KwaiEventLog[]
  utmifyIntegration   UtmifyIntegration?
  utmifyAccounts      UtmifyAccount[]
  blackpayConfig      BlackpayConfig?
}

model TelegramBot {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  botToken    String
  username    String
  webhookUrl  String?
  status      BotStatus @default(PENDING_REVIEW)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  flows       Flow[]
  leads       Lead[]
  facebookPixels FacebookPixel[]
  kwaiAccounts   KwaiAccount[]
  utmifyAccounts UtmifyAccount[]
}

model Acquirer {
  id                String    @id @default(uuid())
  name              String
  slug              String    @unique
  apiKey            String
  apiSecret         String?
  endpointCreatePix String?
  endpointCheckPix  String?
  webhookSecret     String?
  environment       String    @default("production")
  logoUrl           String?
  credentialStatus  String    @default("UNCONFIGURED")
  lastValidatedAt   DateTime?
  lastTestedAt      DateTime?
  priority          Int       @default(0)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Lead {
  id           String   @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  botId        String?
  bot          TelegramBot? @relation(fields: [botId], references: [id], onDelete: SetNull)
  leadUid      String   @unique
  telegramId   String?
  name         String?
  username     String?
  phone        String?
  email        String?
  ip           String?
  userAgent    String?
  externalId   String?
  entryType    String?  // 'deep_link' | 'direct' | null
  startPayload String?  // payload do /start (ex: fluxo_123)
  tags         String[]
  score        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tracking     Tracking?
  events       Event[]
  payments     Payment[]
  segments     Segment[] @relation("LeadSegments")
}

model Tracking {
  id           String  @id @default(uuid())
  leadId       String  @unique
  lead         Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  fbclid       String?
  gclid        String?
  ttclid       String?
  kwaiClickid  String?
  createdAt    DateTime @default(now())
}

model Product {
  id          String            @id @default(uuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal           @db.Decimal(10, 2)
  currency    String            @default("BRL")
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  payments    Payment[]
}

model Payment {
  id            String        @id @default(uuid())
  leadId        String
  lead          Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  transactionId String        @unique
  gateway       String        @default("blackpay")
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("BRL")
  status        PaymentStatus @default(PENDING)
  pixQrCode     String?
  pixCopyPaste  String?
  paidAt        DateTime?
  expiresAt     DateTime?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Event {
  id        String    @id @default(uuid())
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  eventName String
  source    String?
  metadata  Json?
  createdAt DateTime  @default(now())
}

model Flow {
  id           String   @id @default(uuid())
  botId        String?
  bot          TelegramBot? @relation(fields: [botId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  nodes        Json
  edges        Json
  config       Json     @default("{}")
  trigger      String   @default("start")
  isActive     Boolean  @default(false)
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  redirectors  Redirector[]
  versions     FlowVersion[]
}

model FlowVersion {
  id        String   @id @default(uuid())
  flowId    String
  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  version   Int
  nodes     Json
  edges     Json
  config    Json
  createdAt DateTime @default(now())
}

model Automation {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  trigger     String
  conditions  Json?
  actions     Json
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Segment {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  conditions  Json
  leads       Lead[]   @relation("LeadSegments")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FacebookPixel {
  id             String       @id @default(cuid())
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  botId          String?
  bot            TelegramBot? @relation(fields: [botId], references: [id], onDelete: SetNull)
  name           String?
  pixelId        String
  accessToken    String
  isActive       Boolean      @default(true)
  eventPageView  Boolean      @default(true)
  eventAddToCart Boolean      @default(true)
  eventPurchase  Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([workspaceId])
}

model FacebookIntegration {
  id             String   @id @default(uuid())
  workspaceId    String   @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pixelId        String
  accessToken    String
  isActive       Boolean  @default(false)
  eventPageView  Boolean  @default(true)
  eventAddToCart Boolean  @default(true)
  eventPurchase  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model KwaiIntegration {
  id             String   @id @default(uuid())
  workspaceId    String   @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pixelId        String
  accessToken    String
  testToken      String   @default("")
  isActive       Boolean  @default(false)
  eventAddToCart Boolean  @default(true)
  eventPurchase  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model KwaiAccount {
  id             String       @id @default(uuid())
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  botId          String?
  bot            TelegramBot? @relation(fields: [botId], references: [id], onDelete: SetNull)
  name           String?
  pixelId        String
  accessToken    String
  testToken      String       @default("")
  isActive       Boolean      @default(true)
  eventAddToCart Boolean      @default(true)
  eventPurchase  Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([workspaceId])
}

model KwaiEventLog {
  id           String   @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  eventName    String
  pixelId      String
  clickId      String?
  chatId       String?
  orderId      String?
  value        Float?
  status       String   @default("pending")
  response     Json?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([workspaceId])
}

model UtmifyIntegration {
  id              String   @id @default(uuid())
  workspaceId     String   @unique
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  apiKey          String
  webhookUrl      String?
  isActive        Boolean  @default(false)
  eventPixGerado  Boolean  @default(true)
  eventPixPago    Boolean  @default(true)
  pixelId         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UtmifyAccount {
  id             String       @id @default(uuid())
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  botId          String?
  bot            TelegramBot? @relation(fields: [botId], references: [id], onDelete: SetNull)
  name           String?
  apiKey         String
  isActive       Boolean      @default(true)
  eventPixGerado Boolean      @default(true)
  eventPixPago   Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([workspaceId])
}

model UtmifyEventLog {
  id           String   @id @default(uuid())
  workspaceId  String
  chatId       String?
  orderId      String?
  status       String
  valueInCents Int?
  response     Json?
  errorMessage String?
  sentAt       DateTime @default(now())
}

model BlackpayConfig {
  id          String   @id @default(uuid())
  workspaceId String   @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  apiKey      String
  webhookSecret String
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Redirector {
  id                String            @id @default(uuid())
  workspaceId       String
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name              String
  slug              String            @unique
  flowId            String?
  flow              Flow?             @relation(fields: [flowId], references: [id], onDelete: SetNull)
  alternativeUrl    String
  rules             Json              @default("{}")
  isActive          Boolean           @default(true)
  totalClicks       Int               @default(0)
  telegramClicks    Int               @default(0)
  alternativeClicks Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  clicks            RedirectorClick[]
}

model RedirectorClick {
  id           String     @id @default(uuid())
  redirectorId String
  redirector   Redirector @relation(fields: [redirectorId], references: [id], onDelete: Cascade)
  destination  String
  source       String?
  device       String?
  os           String?
  country      String?
  language     String?
  ip           String?
  createdAt    DateTime   @default(now())
}

model UserTracking {
  id            String    @id @default(uuid())
  platform      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  fbclid        String?
  fbp           String?
  fbc           String?
  ttclid        String?
  ttp           String?
  kwaiId        String?
  kwaiPixel     String?
  ip            String?
  userAgent     String?
  chatId        String?
  botStartedAt  DateTime?
  capturedAt    DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([chatId, capturedAt(sort: Desc)])
}

model FacebookEventLog {
  id           String   @id @default(uuid())
  workspaceId  String
  chatId       String?
  eventName    String
  pixelId      String
  orderId      String?
  value        Decimal? @db.Decimal(10, 2)
  status       String
  response     Json?
  errorMessage String?
  sentAt       DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ip          String?
  createdAt   DateTime @default(now())
}
